#!/usr/bin/env bash
set -uo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
ROOT="$(dirname "$SELF")"

export CC_TTS_ROOT="$ROOT"
export PYTHONPATH="$ROOT${PYTHONPATH:+:$PYTHONPATH}"
PATH="$HOME/.local/bin:$PATH"
export PATH

VENV="$ROOT/tts-venv/bin/python"
PYTHON="${CC_TTS_PYTHON:-$([ -x "$VENV" ] && echo "$VENV" || command -v python3)}"

[ -n "$PYTHON" ] || { echo "no python interpreter found" >&2; exit 1; }

cd "$ROOT" || { echo "cannot enter $ROOT" >&2; exit 1; }
exec "$PYTHON" -m tts "$@"
